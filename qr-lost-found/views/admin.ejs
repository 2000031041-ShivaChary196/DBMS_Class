<div class="container">

    <div class="text-center mb-5">
        <h2 class="fw-bold text-danger">Admin Dashboard</h2>
        <p class="text-muted">Manage Users and Items</p>
    </div>

    <div class="row">

        <!-- Users Section -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body">
                    <h4 class="mb-3">👥 All Users</h4>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Role</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(u => { %>
                                <tr>
                                    <td><%= u.name %></td>
                                    <td><%= u.email %></td>
                                    <td>
                                        <span class="badge bg-<%= u.role === 'admin' ? 'danger' : 'secondary' %>">
                                            <%= u.role %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        <!-- Items Section -->
        <div class="col-md-6 mb-4">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body">
                    <h4 class="mb-3">📦 All Items</h4>

                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th>Owner</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% items.forEach(i => { %>
                                <tr>
                                    <td><%= i.itemName %></td>
                                    <td><%= i.user.email %></td>
                                    <td>
                                        <span class="badge bg-<%= i.status === 'lost' ? 'danger' : 'success' %>">
                                            <%= i.status %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

    </div>

</div>